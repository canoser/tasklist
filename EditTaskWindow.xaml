<Window x:Class="planlama_app.EditTaskWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Görevi Düzenle" Width="420" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource MaterialDesign.Brush.Background}"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        FontFamily="{materialDesign:MaterialDesignFont}"
        Style="{StaticResource MaterialDesignWindow}">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <!-- Başlık -->
            <RowDefinition Height="Auto"/>
            <!-- Form Alanı -->
            <RowDefinition Height="*"/>
            <!-- Butonlar -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Başlık -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Görev Bilgilerini Düzenle" 
                       Style="{StaticResource MaterialDesignHeadline5TextBlock}" 
                       HorizontalAlignment="Center"
                       FontWeight="Bold"/>
            <Separator Style="{StaticResource MaterialDesignLightSeparator}" Margin="0,8,0,0"/>
        </StackPanel>

        <!-- Form Elemanları -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,10,0">
                
                <!-- Başlık -->
                <TextBox x:Name="TxtTitle" 
                         materialDesign:HintAssist.Hint="Görev Başlığı" 
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         TextWrapping="Wrap" 
                         AcceptsReturn="True" 
                         Height="70"
                         Margin="0,0,0,16"/>

                <!-- Son Tarih -->
                <DatePicker x:Name="DpDueDate" 
                            materialDesign:HintAssist.Hint="Son Tarih (Seçmeli)" 
                            Style="{StaticResource MaterialDesignOutlinedDatePicker}"
                            Margin="0,0,0,16"/>

                <!-- Süre -->
                <TextBox x:Name="TxtEstTime" 
                         materialDesign:HintAssist.Hint="Yaklaşık Süre (Dakika)" 
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,0,0,16"/>

                <!-- Kategori -->
                <ComboBox x:Name="CmbCategory" 
                          materialDesign:HintAssist.Hint="Kategori" 
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          DisplayMemberPath="Name"
                          SelectedValuePath="Id"
                          Margin="0,0,0,16"/>

                <!-- Görev Türü -->
                <ComboBox x:Name="CmbType" 
                          materialDesign:HintAssist.Hint="Görev Türü" 
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          SelectionChanged="CmbType_SelectionChanged"
                          Margin="0,0,0,16">
                    <ComboBoxItem Content="Bağımsız"/>
                    <ComboBoxItem Content="Zincirleme"/>
                </ComboBox>

                <!-- Zincir ID (Sadece Zincirleme seçildiğinde aktif) -->
                <ComboBox x:Name="CmbChainId" 
                          materialDesign:HintAssist.Hint="Zincir Grubu (Mevcutlardan Seç veya Yaz)" 
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          IsEditable="True"
                          Margin="0,0,0,16"/>

                <!-- Sıra Numarası (Sadece Zincirleme seçildiğinde aktif) -->
                <TextBox x:Name="TxtOrderIndex" 
                         materialDesign:HintAssist.Hint="Sıra Numarası (OrderIndex)" 
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,0,0,16"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Alt Butonlar -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="BtnCancel" 
                    Content="İptal" 
                    Style="{StaticResource MaterialDesignFlatButton}" 
                    Click="BtnCancel_Click" 
                    Margin="0,0,8,0"/>
            
            <Button x:Name="BtnSave" 
                    Content="Kaydet" 
                    Style="{StaticResource MaterialDesignFlatMidBgButton}" 
                    Click="BtnSave_Click" 
                    Width="110"/>
        </StackPanel>
    </Grid>
</Window>
