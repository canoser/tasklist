<Window x:Class="planlama_app.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:conv="clr-namespace:planlama_app.Converters"
        xmlns:views="clr-namespace:planlama_app.Views"
        mc:Ignorable="d"
        Title="TaskList - Görev &amp; Planlama Yönetimi"
        Height="760" Width="1180"
        MinHeight="550" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource MaterialDesign.Brush.Background}"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        FontFamily="{materialDesign:MaterialDesignFont}"
        Style="{StaticResource MaterialDesignWindow}"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <conv:GroupExpandedConverter x:Key="GroupExpandedConverter"/>
        <conv:GroupColorConverter x:Key="GroupColorConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Üst Bar -->
            <RowDefinition Height="Auto"/>
            <!-- Sekmeler (Görev Grupları) -->
            <RowDefinition Height="Auto"/>
            <!-- Görünüm Seçici & Filtre Çubuğu -->
            <RowDefinition Height="Auto"/>
            <!-- İçerik (Takvim / Liste / Bölünmüş) -->
            <RowDefinition Height="*"/>
            <!-- Durum Çubuğu -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════
             ÜST BAR (Header)
        ═══════════════════════════════════════════════════════════ -->
        <materialDesign:ColorZone Grid.Row="0"
                                  Mode="PrimaryMid"
                                  Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Sol: Başlık + İkon -->
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="CalendarCheck"
                                             Width="28" Height="28"
                                             VerticalAlignment="Center"
                                             Margin="0,0,10,0"/>
                    <TextBlock Text="TaskList"
                               Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="Planlama &amp; Görev Yönetimi"
                               FontSize="12"
                               Opacity="0.8"
                               VerticalAlignment="Bottom"
                               Margin="12,0,0,3"/>
                </StackPanel>

                <!-- Sağ: Butonlar -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right">

                    <!-- Tema Seçici -->
                    <ComboBox x:Name="CmbTheme"
                              SelectionChanged="CmbTheme_SelectionChanged"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              Foreground="White"
                              BorderBrush="White"
                              materialDesign:HintAssist.Hint="Tema"
                              materialDesign:HintAssist.Foreground="White"
                              Margin="0,0,16,0"
                              Width="140"
                              Padding="8,6">
                        <ComboBoxItem Content="Koyu Tema (Dark)"/>
                        <ComboBoxItem Content="Monokai"/>
                        <ComboBoxItem Content="Monokai Dimmed"/>
                        <ComboBoxItem Content="Abyss"/>
                        <ComboBoxItem Content="Tokyo Night Light"/>
                    </ComboBox>

                    <!-- Kaynaklar (Sidebar) Butonu -->
                    <Button x:Name="BtnToggleSidebar"
                            Click="BtnToggleSidebar_Click"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Foreground="White" BorderBrush="White"
                            Margin="0,0,8,0"
                            Padding="16,6"
                            ToolTip="Kaynaklar panelini aç/kapat">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="BookmarkMultipleOutline"
                                                    Width="20" Height="20"
                                                    VerticalAlignment="Center"
                                                    Margin="0,0,8,0"/>
                            <TextBlock Text="Kaynaklar"
                                       VerticalAlignment="Center"
                                       FontWeight="Medium"/>
                        </StackPanel>
                    </Button>

                    <!-- Txt'den İçe Aktar -->
                    <Button x:Name="BtnImport"
                            Click="BtnImport_Click"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Foreground="White" BorderBrush="White"
                            Margin="0,0,8,0"
                            Padding="16,6"
                            ToolTip="Bir .txt dosyasından görevleri içe aktar">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="FileImport"
                                                    Width="20" Height="20"
                                                    VerticalAlignment="Center"
                                                    Margin="0,0,8,0"/>
                            <TextBlock Text="İçe Aktar"
                                       VerticalAlignment="Center"
                                       FontWeight="Medium"/>
                        </StackPanel>
                    </Button>

                    <!-- Şablon (AI/LLM) -->
                    <Button x:Name="BtnTemplate"
                            Click="BtnTemplate_Click"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Foreground="White" BorderBrush="White"
                            Margin="0,0,12,0"
                            Padding="16,6"
                            ToolTip="AI/LLM için örnek dosya şablonu oluştur ve göster">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="FileDocumentEditOutline"
                                                    Width="20" Height="20"
                                                    VerticalAlignment="Center"
                                                    Margin="0,0,8,0"/>
                            <TextBlock Text="Şablon"
                                       VerticalAlignment="Center"
                                       FontWeight="Medium"/>
                        </StackPanel>
                    </Button>

                    <!-- Geri Al -->
                    <Button x:Name="BtnUndo"
                            Click="BtnUndo_Click"
                            Style="{StaticResource MaterialDesignIconButton}"
                            Foreground="White"
                            Margin="0,0,8,0"
                            IsEnabled="False"
                            ToolTip="Geri Al (Ctrl+Z)">
                        <materialDesign:PackIcon Kind="Undo" Width="22" Height="22"/>
                    </Button>

                    <!-- Yenile -->
                    <Button x:Name="BtnRefresh"
                            Click="BtnRefresh_Click"
                            Style="{StaticResource MaterialDesignIconButton}"
                            Foreground="White"
                            ToolTip="Listeyi yenile">
                        <materialDesign:PackIcon Kind="Refresh" Width="22" Height="22"/>
                    </Button>
                </StackPanel>
            </Grid>
        </materialDesign:ColorZone>

        <!-- ═══════════════════════════════════════════════════════════
             KATEGORİ SEKMELERİ (Görev Grupları)
        ═══════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1" Background="{DynamicResource MaterialDesign.Brush.Background}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.ColumnSpan="2" BorderBrush="{DynamicResource MaterialDesign.Brush.Divider}" BorderThickness="0,0,0,1" VerticalAlignment="Bottom"/>
            <TabControl x:Name="TabCategories"
                        Grid.Column="0"
                        Style="{StaticResource MaterialDesignTabControl}"
                        SelectionChanged="TabCategories_SelectionChanged"
                        Margin="0,0,0,1">
            </TabControl>

            <Button x:Name="BtnAddCategory"
                    Grid.Column="1"
                    Style="{StaticResource MaterialDesignIconButton}"
                    Click="BtnAddCategory_Click"
                    ToolTip="Yeni Görev Grubu / Kategori Ekle"
                    Margin="8,0">
                <materialDesign:PackIcon Kind="Plus" Width="24" Height="24"/>
            </Button>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════
             FİLTRE ÇUBUĞU & GÖRÜNÜM MODLARI
        ═══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2"
                Background="{DynamicResource MaterialDesign.Brush.Background}"
                Padding="16,8"
                BorderBrush="{DynamicResource MaterialDesign.Brush.DataGrid.RowHoverBackground}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Sol: Arama ve Filtreler -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">

                    <!-- Arama Kutusu -->
                    <TextBox x:Name="TxtSearch"
                             Width="240"
                             materialDesign:HintAssist.Hint="Görev ara..."
                             materialDesign:HintAssist.IsFloating="False"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Padding="8,6"
                             TextChanged="TxtSearch_TextChanged"
                             Margin="0,0,12,0"/>

                    <!-- Tür Filtresi -->
                    <ComboBox x:Name="CmbFilter"
                              Width="140"
                              materialDesign:HintAssist.Hint="Görev Türü"
                              materialDesign:HintAssist.IsFloating="False"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              Padding="8,6"
                              SelectionChanged="CmbFilter_SelectionChanged"
                              Margin="0,0,12,0">
                        <ComboBoxItem Content="Tüm Türler" IsSelected="True"/>
                        <ComboBoxItem Content="Bağımsız"/>
                        <ComboBoxItem Content="Zincirleme"/>
                    </ComboBox>

                    <!-- Tamamlananları Gizle -->
                    <CheckBox x:Name="ChkHideCompleted"
                              Content="Tamamlananları Gizle"
                              Style="{StaticResource MaterialDesignCheckBox}"
                              Checked="Filter_Changed"
                              Unchecked="Filter_Changed"
                              VerticalAlignment="Center"/>

                    <!-- Seçilenleri Sil -->
                    <Button x:Name="BtnDeleteSelected"
                            Click="BtnDeleteSelected_Click"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Foreground="Red"
                            Margin="12,0,0,0"
                            VerticalAlignment="Center"
                            IsEnabled="False"
                            ToolTip="Seçili görevleri toplu sil">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="TrashCanOutline" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Seçilenleri Sil" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>

                    <!-- Toplam Sayaç -->
                    <TextBlock x:Name="TxtCount"
                               Text="0 görev"
                               Style="{StaticResource MaterialDesignBody2TextBlock}"
                               Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
                               Opacity="0.6"
                               VerticalAlignment="Center"
                               Margin="16,0,0,0"/>
                </StackPanel>

                <!-- Sağ: Görünüm Modu Değiştirici (Takvim / Liste / Bölünmüş) -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Görünüm:" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="Medium" Opacity="0.7"/>
                    
                    <!-- Mode Switcher Buttons -->
                    <Border CornerRadius="6" Background="{DynamicResource MaterialDesign.Brush.ToolBar.Background}" Padding="2">
                        <StackPanel Orientation="Horizontal">
                            <RadioButton x:Name="RbViewCalendar" Content="📅 Takvim" 
                                         GroupName="ViewModeGroup" Style="{StaticResource MaterialDesignTabRadioButton}" 
                                         Click="ViewMode_Click" Tag="Calendar" Margin="2,0"/>
                            <RadioButton x:Name="RbViewSplit" Content="🔀 Bölünmüş" 
                                         GroupName="ViewModeGroup" Style="{StaticResource MaterialDesignTabRadioButton}" 
                                         Click="ViewMode_Click" Tag="Split" IsChecked="True" Margin="2,0"/>
                            <RadioButton x:Name="RbViewList" Content="📋 Liste" 
                                         GroupName="ViewModeGroup" Style="{StaticResource MaterialDesignTabRadioButton}" 
                                         Click="ViewMode_Click" Tag="List" Margin="2,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════
             İÇERİK (Takvim & Liste Görünümleri)
        ═══════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Ana Görünüm Alanı (Grid for Calendar + List split) -->
            <Grid Grid.Column="0">
                <Grid.ColumnDefinitions>
                    <!-- Column 0: Takvim -->
                    <ColumnDefinition x:Name="ColCalendar" Width="1.2*"/>
                    <!-- GridSplitter -->
                    <ColumnDefinition x:Name="ColSplitter" Width="Auto"/>
                    <!-- Column 2: Liste -->
                    <ColumnDefinition x:Name="ColList" Width="1*"/>
                </Grid.ColumnDefinitions>

                <!-- TAKVİM KONTROLÜ -->
                <Border x:Name="BorderCalendar" Grid.Column="0" Margin="4">
                    <views:CalendarView x:Name="CalendarControl"/>
                </Border>

                <!-- SPLITTER -->
                <GridSplitter x:Name="ViewSplitter" Grid.Column="1" Width="5" HorizontalAlignment="Stretch" 
                              Background="{DynamicResource MaterialDesign.Brush.Divider}" Margin="0,4"/>

                <!-- GÖREV LİSTESİ ALANI -->
                <Grid x:Name="GridTaskListArea" Grid.Column="2">
                    <!-- Boş durum mesajı -->
                    <StackPanel x:Name="PanelEmpty"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Visibility="Collapsed">
                        <materialDesign:PackIcon Kind="ClipboardTextOutline"
                                                Width="64" Height="64"
                                                HorizontalAlignment="Center"
                                                Opacity="0.25"/>
                        <TextBlock Text="Görev bulunamadı"
                                   Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                                   HorizontalAlignment="Center"
                                   Opacity="0.4"
                                   Margin="0,8,0,4"/>
                        <TextBlock Text="Aşağıdaki buton ile yeni görev veya içe aktarma yapabilirsiniz."
                                   Style="{StaticResource MaterialDesignBody2TextBlock}"
                                   HorizontalAlignment="Center"
                                   Opacity="0.3"
                                   TextAlignment="Center"
                                   Margin="0,0,0,12"/>
                        <Button x:Name="BtnEmptyImport" Click="BtnImport_Click"
                                Style="{StaticResource MaterialDesignFlatMidBgButton}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="FileImport" Width="18" Height="18" Margin="0,0,6,0"/>
                                <TextBlock Text="İçe Aktar"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- ListView -->
                    <ListView x:Name="LvTasks"
                              ItemsSource="{Binding}"
                              SelectionMode="Single"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              Margin="8,4,8,4"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.ScrollUnit="Pixel"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              VirtualizingPanel.IsVirtualizingWhenGrouping="True">
                        <ListView.GroupStyle>
                            <GroupStyle>
                                <GroupStyle.ContainerStyle>
                                    <Style TargetType="{x:Type GroupItem}">
                                        <Setter Property="Margin" Value="0,6,0,4"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="{x:Type GroupItem}">
                                                    <Expander IsExpanded="{Binding Name, Converter={StaticResource GroupExpandedConverter}, Mode=OneWay}"
                                                              Margin="2,2,2,2">
                                                        <Expander.Header>
                                                            <StackPanel Orientation="Horizontal" Margin="4,2">
                                                                <Border Width="12" Height="12" CornerRadius="6" 
                                                                        Background="{Binding Name, Converter={StaticResource GroupColorConverter}}" 
                                                                        Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                                <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                                                                <Border Background="{DynamicResource MaterialDesign.Brush.ToolBar.Background}" CornerRadius="10" Padding="6,1" Margin="8,0,0,0" VerticalAlignment="Center">
                                                                    <TextBlock Text="{Binding ItemCount, StringFormat='{}{0} görev'}" FontSize="11" Opacity="0.7"/>
                                                                </Border>
                                                                
                                                                <CheckBox Style="{StaticResource MaterialDesignCheckBox}" Margin="16,0,0,0" VerticalAlignment="Center"
                                                                          Tag="{Binding Name}" Checked="ChkSelectGroup_Checked" Unchecked="ChkSelectGroup_Unchecked" ToolTip="Grubun tümünü seç"/>
                                                            </StackPanel>
                                                        </Expander.Header>
                                                        <ItemsPresenter />
                                                    </Expander>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </GroupStyle.ContainerStyle>
                            </GroupStyle>
                        </ListView.GroupStyle>

                        <ListView.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:TaskItem}" xmlns:models="clr-namespace:planlama_app.Models">
                                <Border BorderBrush="{DynamicResource MaterialDesign.Brush.Divider}" BorderThickness="0,0,0,1" Padding="8,8,8,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Seçim ve Durum Checkbox -->
                                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" Style="{StaticResource MaterialDesignCheckBox}" Checked="ChkItem_Changed" Unchecked="ChkItem_Changed" ToolTip="Seç" Margin="0,0,4,0"/>
                                            <CheckBox IsChecked="{Binding IsCompleted, Mode=TwoWay}" Style="{StaticResource MaterialDesignCheckBox}" Click="ChkCompleted_Click" ToolTip="Tamamlandı olarak işaretle"/>
                                        </StackPanel>

                                        <!-- Detaylar -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="4,0,8,0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Title}" FontWeight="Medium" FontSize="13">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                                    <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                                    <Setter Property="Opacity" Value="0.5"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>

                                                <Border Visibility="{Binding CategoryName, Converter={StaticResource GroupExpandedConverter}}" Background="{DynamicResource MaterialDesign.Brush.Primary.Light}" CornerRadius="4" Padding="4,1" Margin="8,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding CategoryName}" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource MaterialDesign.Brush.Primary.Foreground}"/>
                                                </Border>
                                            </StackPanel>

                                            <!-- Ek bilgiler: Tarih, Süre, Zincir -->
                                            <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                <TextBlock Text="{Binding DueDate, StringFormat='📅 {0:dd.MM.yyyy}'}" FontSize="11" Opacity="0.7" Margin="0,0,12,0"/>
                                                
                                                <TextBlock Visibility="{Binding EstimatedTime, Converter={StaticResource GroupExpandedConverter}}"
                                                           Text="{Binding EstimatedTime, StringFormat='⏱ {0} dk'}" FontSize="11" Opacity="0.7" Margin="0,0,12,0"/>

                                                <TextBlock Visibility="{Binding ChainId, Converter={StaticResource GroupExpandedConverter}}"
                                                           Text="{Binding ChainId, StringFormat='⛓ {0}'}" FontSize="11" Foreground="DodgerBlue" Margin="0,0,12,0"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- İşlem Butonları -->
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button Click="BtnPostpone_Click" Tag="{Binding}" Style="{StaticResource MaterialDesignIconButton}" Width="28" Height="28" ToolTip="1 Gün Ertele" Margin="0,0,4,0">
                                                <materialDesign:PackIcon Kind="ClockPlusOutline" Width="16" Height="16"/>
                                            </Button>

                                            <Button Click="BtnEdit_Click" Tag="{Binding}" Style="{StaticResource MaterialDesignIconButton}" Width="28" Height="28" ToolTip="Düzenle" Margin="0,0,4,0">
                                                <materialDesign:PackIcon Kind="Pencil" Width="16" Height="16"/>
                                            </Button>

                                            <Button Click="BtnDelete_Click" Tag="{Binding}" Style="{StaticResource MaterialDesignIconButton}" Foreground="Red" Width="28" Height="28" ToolTip="Sil">
                                                <materialDesign:PackIcon Kind="TrashCanOutline" Width="16" Height="16"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Grid>

            <!-- ═══════════════════════════════════════════════════════════
                 SAĞ YAN PANEL (Kaynaklar / Sidebar)
            ═══════════════════════════════════════════════════════════ -->
            <Border x:Name="SidebarBorder"
                    Grid.Column="1"
                    Visibility="Collapsed"
                    Width="300"
                    Background="{DynamicResource MaterialDesign.Brush.CardBackground}"
                    BorderBrush="{DynamicResource MaterialDesign.Brush.Divider}"
                    BorderThickness="1,0,0,0">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <TextBlock Text="🔖 Kaynaklar &amp; Notlar" Style="{StaticResource MaterialDesignSubtitle1TextBlock}" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Button Click="BtnCloseSidebar_Click" Style="{StaticResource MaterialDesignIconButton}" HorizontalAlignment="Right" Width="24" Height="24">
                            <materialDesign:PackIcon Kind="Close" Width="16" Height="16"/>
                        </Button>
                    </Grid>

                    <ListView x:Name="LvResources" Grid.Row="1" SelectionMode="Single" Margin="0,4">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,4">
                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Content}" TextWrapping="Wrap" Opacity="0.7" FontSize="11"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <Button Grid.Row="2" Click="BtnAddResource_Click" Style="{StaticResource MaterialDesignOutlinedButton}" Margin="0,8,0,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Plus" Width="16" Height="16" Margin="0,0,6,0"/>
                            <TextBlock Text="Yeni Kaynak Ekle"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════
             DURUM ÇUBUĞU & YÜKLENİYOR SİMGESİ
        ═══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="4"
                Background="{DynamicResource MaterialDesign.Brush.ToolBar.Background}"
                Padding="12,4"
                BorderBrush="{DynamicResource MaterialDesign.Brush.Divider}"
                BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <ProgressBar x:Name="LoadingSpinner"
                                 Style="{StaticResource MaterialDesignCircularProgressBar}"
                                 Value="0" IsIndeterminate="True"
                                 Width="14" Height="14"
                                 Visibility="Collapsed"
                                 Margin="0,0,8,0"/>
                    <TextBlock x:Name="TxtStatus"
                               Text="Hazır."
                               FontSize="12"
                               Opacity="0.8"/>
                </StackPanel>

                <TextBlock Grid.Column="1" Text="TaskList v1.1" FontSize="11" Opacity="0.5"/>
            </Grid>
        </Border>
    </Grid>
</Window>
