<UserControl x:Class="planlama_app.Views.CalendarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <UserControl.Resources>
        <Style x:Key="CalendarDayHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,6"/>
            <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Foreground}"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource MaterialDesign.Brush.Background}">
        <Grid.RowDefinitions>
            <!-- Header: Ay/Yıl ve Navigasyon -->
            <RowDefinition Height="Auto"/>
            <!-- Hafta Günleri (Pzt-Paz) -->
            <RowDefinition Height="Auto"/>
            <!-- Takvim Günleri Matrisi -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════
             ÜST NAVİGASYON (Ay Seçimi)
        ═══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Padding="16,12" 
                BorderBrush="{DynamicResource MaterialDesign.Brush.Divider}" 
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Sol: Ay İlerleme Butonları -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button x:Name="BtnPrevMonth" Click="BtnPrevMonth_Click"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Padding="8,4" Height="36" Margin="0,0,6,0"
                            ToolTip="Önceki Ay">
                        <materialDesign:PackIcon Kind="ChevronLeft" Width="20" Height="20"/>
                    </Button>
                    <Button x:Name="BtnToday" Click="BtnToday_Click"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Padding="12,4" Height="36" Margin="0,0,6,0">
                        <TextBlock Text="Bugün" FontWeight="Medium"/>
                    </Button>
                    <Button x:Name="BtnNextMonth" Click="BtnNextMonth_Click"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Padding="8,4" Height="36"
                            ToolTip="Sonraki Ay">
                        <materialDesign:PackIcon Kind="ChevronRight" Width="20" Height="20"/>
                    </Button>
                </StackPanel>

                <!-- Orta: Ay ve Yıl Başlığı -->
                <TextBlock x:Name="TxtMonthYear" Grid.Column="1"
                           Text="Temmuz 2026"
                           Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>

                <!-- Sağ: Özet Bilgi -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:Chip Content="Bu Ayki Görevler"
                                         Icon="{materialDesign:PackIcon Kind=CalendarTask}"
                                         Background="{DynamicResource MaterialDesign.Brush.Primary.Light}"
                                         Foreground="{DynamicResource MaterialDesign.Brush.Primary.Foreground}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════
             HAFTA GÜNLERİ BAŞLIĞI
        ═══════════════════════════════════════════════════════════ -->
        <UniformGrid Grid.Row="1" Columns="7" 
                     Background="{DynamicResource MaterialDesign.Brush.ToolBar.Background}">
            <TextBlock Text="Pzt" Style="{StaticResource CalendarDayHeaderStyle}"/>
            <TextBlock Text="Sal" Style="{StaticResource CalendarDayHeaderStyle}"/>
            <TextBlock Text="Çar" Style="{StaticResource CalendarDayHeaderStyle}"/>
            <TextBlock Text="Per" Style="{StaticResource CalendarDayHeaderStyle}"/>
            <TextBlock Text="Cum" Style="{StaticResource CalendarDayHeaderStyle}"/>
            <TextBlock Text="Cmt" Style="{StaticResource CalendarDayHeaderStyle}" Foreground="#E53935"/>
            <TextBlock Text="Paz" Style="{StaticResource CalendarDayHeaderStyle}" Foreground="#E53935"/>
        </UniformGrid>

        <!-- ═══════════════════════════════════════════════════════════
             TAKVİM MATRİSİ (Dynamic Grid)
        ═══════════════════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <UniformGrid x:Name="GridCalendarDays" Columns="7" Rows="6" Margin="4"/>
        </ScrollViewer>
    </Grid>
</UserControl>
