<Application x:Class="planlama_app.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:planlama_app"
             xmlns:conv="clr-namespace:planlama_app.Converters"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Material Design Tema Kaynakları -->
                <materialDesign:BundledTheme
                    BaseTheme="Dark"
                    PrimaryColor="DeepPurple"
                    SecondaryColor="Cyan" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml"/>
                
                <!-- Modern Scrollbar Theme -->
                <ResourceDictionary Source="Themes/ScrollbarTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Value Converters -->
            <conv:BoolToOpacityConverter     x:Key="BoolToOpacityConverter"/>
            <conv:BoolToCheckIconConverter   x:Key="BoolToCheckIconConverter"/>
            <conv:BoolToGreenGrayConverter   x:Key="BoolToGreenGrayConverter"/>
            <conv:DueDateToColorConverter    x:Key="DueDateToColorConverter"/>
            <conv:TaskTypeToBrushConverter   x:Key="TaskTypeToBrushConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
